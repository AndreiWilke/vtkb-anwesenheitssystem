# Alle Textdateien normalisiert mit LF im Repository
* text=auto eol=lf

# Explizit LF fuer diese Typen
*.ts   text eol=lf
*.tsx  text eol=lf
*.js   text eol=lf
*.mjs  text eol=lf
*.cjs  text eol=lf
*.json text eol=lf
*.md   text eol=lf
*.css  text eol=lf
